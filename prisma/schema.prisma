generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Off-chain API key storage (secrets can never go on-chain)
// agentId maps to the on-chain uint256 agent ID (stored as String)
model AgentKey {
  id         String   @id @default(cuid())
  agentId    String   @unique // on-chain agent ID as string (e.g. "1", "42")
  apiKeyHash String
  keyPrefix  String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  verifyLogs    VerifyLog[]
  notifications Notification[]
}

// Audit trail for every /api/verify call
model VerifyLog {
  id        String   @id @default(cuid())
  agentId   String   // on-chain agent ID
  scope     String
  service   String   @default("")
  status    String   // "allowed" | "denied" | "pending_approval" | "agent_inactive" | "invalid_key"
  ip        String   @default("")
  createdAt DateTime @default(now())

  agentKey AgentKey @relation(fields: [agentId], references: [agentId])
}

// Off-chain staging area for on-chain permission decisions
// "approve" triggers a grantPermission() tx; "deny" stays off-chain only
model Notification {
  id            String   @id @default(cuid())
  agentId       String   // on-chain agent ID
  walletAddress String   // lowercase 0x address of agent owner
  scope         String
  service       String   @default("")
  status        String   @default("pending") // "pending" | "approved" | "denied"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agentKey AgentKey @relation(fields: [agentId], references: [agentId])

  @@unique([agentId, scope, status])
}
